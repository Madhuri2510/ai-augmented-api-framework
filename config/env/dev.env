#  DEV environment #
# Used for local development and feature-branch testing.
# Points at the public Restful-Booker sandbox.

BASE_URL=https://restful-booker.herokuapp.com
BOOKER_USERNAME=admin
BOOKER_PASSWORD=password123

# Optional — enables AI agent features (generate:tests, agent:report)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# How long to wait between write operations (ms) — be polite to the public API
THROTTLE_MS=200